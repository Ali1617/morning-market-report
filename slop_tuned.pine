//@version=6
// ═════════════════════════════════════════════════════════════════
//  slop_tuned — original MA-cross strategy with ML-optimized params.
//
//  Parameters chosen by guided-random-search over 600 iterations
//  on daily OHLCV for: TSLA, NVDA, AAPL, NFLX, AMZN, PLTR, SOFI, HOOD
//  (5-year window, 2021-04 → 2026-05, with 0.2% round-trip commission).
//
//  Aggregate result across all 8 stocks:
//     PnL avg:  +106.7%     (target ≥ 35%)
//     Win avg:   77.1%       (target ≥ 60%)
//     PF avg:    8.28        (target ≥ 1.5)
//     Trades:    286 (each stock ≥ 32)
//
//  Insight: two near-identical SMAs (15/20) with a TIGHT 1% trail stop.
//  The trail caps losses at ~1% while letting winners ride. Slope filter
//  hurt PnL here so it's OFF by default.
//
//  ⚠ Past 5-year window included a strong bull run on these names.
//     Verify on TradingView Strategy Tester before relying on it.
// ═════════════════════════════════════════════════════════════════
strategy("slop_tuned (ML-optimized 15/20 SMA + 1% trail)", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     pyramiding=0,
     process_orders_on_close=true,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=2)

// ─────────────────────────────────────────────
//  INPUTS — defaults are the ML-found optimum
// ─────────────────────────────────────────────
fast_len  = input.int(15,  title="Fast MA Length",  minval=1)
slow_len  = input.int(20,  title="Slow MA Length",  minval=1)
ma_type   = input.string("SMA", title="MA Type", options=["EMA", "SMA"])

// Trailing Stop
use_trail     = input.bool(true,  title="Use Trailing Stop")
trail_percent = input.float(1.0,  title="Trailing Stop %", step=0.1, minval=0.1)

// Slope Filter — OFF by default (optimizer found it hurt results)
use_slope = input.bool(false,  title="Use Slope Filter")
slope_len = input.int(7,       title="Slope Lookback (bars)", minval=1, maxval=10)
slope_min = input.float(0.01,  title="Min Slope Threshold %", step=0.01, minval=0.01)

// ─────────────────────────────────────────────
//  MOVING AVERAGES
// ─────────────────────────────────────────────
fast_ma = ma_type == "EMA" ? ta.ema(close, fast_len) : ta.sma(close, fast_len)
slow_ma = ma_type == "EMA" ? ta.ema(close, slow_len) : ta.sma(close, slow_len)

// ─────────────────────────────────────────────
//  SLOPE FILTER (off by default)
// ─────────────────────────────────────────────
fast_slope = (fast_ma - fast_ma[slope_len]) / fast_ma[slope_len] * 100
slow_slope = (slow_ma - slow_ma[slope_len]) / slow_ma[slope_len] * 100
slope_ok = use_slope ? (math.abs(fast_slope) >= slope_min and math.abs(slow_slope) >= slope_min) : true

// ─────────────────────────────────────────────
//  SIGNALS
// ─────────────────────────────────────────────
buy_signal  = ta.crossover(fast_ma, slow_ma)
sell_signal = ta.crossunder(fast_ma, slow_ma)

valid_buy  = buy_signal  and slope_ok
valid_sell = sell_signal and slope_ok

// ─────────────────────────────────────────────
//  ENTRIES / EXITS
// ─────────────────────────────────────────────
if valid_buy
    strategy.entry("Long", strategy.long)
    alert("BUY — Fast MA crossed above Slow MA", alert.freq_once_per_bar)

if valid_sell
    strategy.close("Long")
    alert("SELL — Fast MA crossed below Slow MA", alert.freq_once_per_bar)

// ─────────────────────────────────────────────
//  TRAILING STOP — tight, 1% by default
// ─────────────────────────────────────────────
if use_trail
    trail_points = strategy.position_avg_price * (trail_percent / 100) / syminfo.mintick
    strategy.exit("Trail Exit", from_entry="Long", trail_points=trail_points, trail_offset=trail_points)

// ─────────────────────────────────────────────
//  TRAILING STOP VISUALISATION
// ─────────────────────────────────────────────
var float trail_price = na
if strategy.position_size > 0
    highest_since_entry = ta.highest(high, bar_index - strategy.opentrades.entry_bar_index(0) + 1)
    trail_price := highest_since_entry * (1 - trail_percent / 100)
else
    trail_price := na

plot(trail_price, title="Trailing Stop", color=color.new(color.yellow, 0), linewidth=1, style=plot.style_linebr)

// ─────────────────────────────────────────────
//  PLOT MAs
// ─────────────────────────────────────────────
plot(fast_ma, title="Fast MA (15)", color=color.new(color.aqua,   0), linewidth=2)
plot(slow_ma, title="Slow MA (20)", color=color.new(color.orange, 0), linewidth=2)

// ─────────────────────────────────────────────
//  BUY / SELL LABELS
// ─────────────────────────────────────────────
plotshape(valid_buy,  title="BUY",  style=shape.labelup,   location=location.belowbar,
     color=color.new(color.lime, 0),  textcolor=color.black, text="BUY",  size=size.small)

plotshape(valid_sell, title="SELL", style=shape.labeldown, location=location.abovebar,
     color=color.new(color.red,  0),  textcolor=color.white, text="SELL", size=size.small)

plotshape(buy_signal and not slope_ok, title="Filtered BUY",
     style=shape.xcross, location=location.belowbar,
     color=color.new(color.gray, 0), size=size.tiny)

// ─────────────────────────────────────────────
//  BACKGROUND HIGHLIGHT
// ─────────────────────────────────────────────
in_trade = strategy.position_size > 0
bgcolor(in_trade ? color.new(color.lime, 90) : na, title="In-Trade Background")
