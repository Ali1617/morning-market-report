//@version=6
strategy("slop_v2_bidirectional", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     pyramiding=0,
     process_orders_on_close=true,
     commission_type=strategy.commission.percent,
     commission_value=0.04,
     slippage=2)

// ═════════════════════════════════════════════
//  INPUTS
// ═════════════════════════════════════════════

// Moving Averages
fast_len   = input.int(9,    title="Fast MA Length",  minval=1, group="Moving Averages")
slow_len   = input.int(21,   title="Slow MA Length",  minval=1, group="Moving Averages")
trend_len  = input.int(200,  title="Trend MA Length", minval=50, group="Moving Averages")
ma_type    = input.string("EMA", title="MA Type", options=["EMA", "SMA"], group="Moving Averages")

// Trade Direction
allow_long       = input.bool(true, title="Allow Long Trades",  group="Direction")
allow_short      = input.bool(true, title="Allow Short Trades", group="Direction")
use_trend_filter = input.bool(true, title="Require price on correct side of Trend MA", group="Direction")

// Slope Filter
use_slope = input.bool(true,  title="Use Slope Filter", group="Slope")
slope_len = input.int(3,      title="Slope Lookback (bars)", minval=1, maxval=10, group="Slope")
slope_min = input.float(0.05, title="Min Slope Threshold %", step=0.01, minval=0.01, group="Slope")

// RSI Momentum Filter
use_rsi       = input.bool(true, title="Use RSI Filter", group="Momentum")
rsi_len       = input.int(14,    title="RSI Length", minval=2, group="Momentum")
rsi_long_max  = input.float(70,  title="Skip Long if RSI >",  minval=50, maxval=90, group="Momentum")
rsi_short_min = input.float(30,  title="Skip Short if RSI <", minval=10, maxval=50, group="Momentum")

// ADX Trend Strength Filter
use_adx = input.bool(true, title="Use ADX Trend Strength Filter", group="Trend Strength")
adx_len = input.int(14,    title="ADX Length", minval=2, group="Trend Strength")
adx_min = input.float(20,  title="Min ADX",     minval=10, maxval=50, group="Trend Strength")

// Volume Filter
use_volume = input.bool(false, title="Use Volume Filter", group="Volume")
vol_ma_len = input.int(20,     title="Volume MA Length",  minval=1, group="Volume")
vol_mult   = input.float(1.0,  title="Volume Multiplier", step=0.1, minval=0.1, group="Volume")

// Risk Management — ATR Stops
use_atr_stop   = input.bool(true,  title="Use ATR-based Stops (else fixed %)", group="Risk")
atr_len        = input.int(14,     title="ATR Length", minval=1, group="Risk")
atr_stop_mult  = input.float(2.0,  title="ATR Initial Stop Multiplier", step=0.1, minval=0.5, group="Risk")
atr_trail_mult = input.float(2.5,  title="ATR Trail Multiplier",        step=0.1, minval=0.5, group="Risk")
stop_pct       = input.float(1.5,  title="Fallback Stop %",             step=0.1, minval=0.1, group="Risk")

// Take Profit
use_tp   = input.bool(true, title="Use Take-Profit", group="Risk")
rr_ratio = input.float(2.0, title="Risk:Reward Ratio", step=0.1, minval=0.5, group="Risk")

// Trailing
use_trail = input.bool(true, title="Use Trailing Stop", group="Risk")

// Opposite-cross exit (faster reversal capture)
exit_on_opp_cross = input.bool(false, title="Also exit on opposite MA cross", group="Risk")

// Session Filter
use_session = input.bool(false,          title="Use Session Filter", group="Session")
sess_input  = input.session("0930-1600", title="Trade Session",      group="Session")

// ═════════════════════════════════════════════
//  CALCULATIONS
// ═════════════════════════════════════════════

f_ma(src, len) =>
    ma_type == "EMA" ? ta.ema(src, len) : ta.sma(src, len)

fast_ma  = f_ma(close, fast_len)
slow_ma  = f_ma(close, slow_len)
trend_ma = f_ma(close, trend_len)

// Slope
fast_slope = (fast_ma - fast_ma[slope_len]) / fast_ma[slope_len] * 100
slow_slope = (slow_ma - slow_ma[slope_len]) / slow_ma[slope_len] * 100
slope_up   = fast_slope >=  slope_min and slow_slope >=  slope_min
slope_down = fast_slope <= -slope_min and slow_slope <= -slope_min
slope_ok_long  = use_slope ? slope_up   : true
slope_ok_short = use_slope ? slope_down : true

// RSI
rsi_val = ta.rsi(close, rsi_len)
rsi_ok_long  = use_rsi ? rsi_val < rsi_long_max  : true
rsi_ok_short = use_rsi ? rsi_val > rsi_short_min : true

// ADX
[diPlus, diMinus, adx] = ta.dmi(adx_len, adx_len)
adx_ok = use_adx ? adx >= adx_min : true

// Volume
vol_ma = ta.sma(volume, vol_ma_len)
vol_ok = use_volume ? volume >= vol_ma * vol_mult : true

// Trend filter
trend_ok_long  = use_trend_filter ? close > trend_ma : true
trend_ok_short = use_trend_filter ? close < trend_ma : true

// Session
in_session = use_session ? not na(time(timeframe.period, sess_input)) : true

// ATR-based distances
atr_val    = ta.atr(atr_len)
stop_dist  = use_atr_stop ? atr_val * atr_stop_mult  : close * stop_pct / 100
trail_dist = use_atr_stop ? atr_val * atr_trail_mult : close * stop_pct / 100

// ═════════════════════════════════════════════
//  SIGNALS
// ═════════════════════════════════════════════
cross_up   = ta.crossover(fast_ma,  slow_ma)
cross_down = ta.crossunder(fast_ma, slow_ma)

valid_long  = allow_long  and cross_up   and slope_ok_long  and rsi_ok_long  and adx_ok and vol_ok and trend_ok_long  and in_session
valid_short = allow_short and cross_down and slope_ok_short and rsi_ok_short and adx_ok and vol_ok and trend_ok_short and in_session

filtered_long  = cross_up   and not valid_long  and allow_long
filtered_short = cross_down and not valid_short and allow_short

// ═════════════════════════════════════════════
//  STRATEGY STATE
// ═════════════════════════════════════════════
var float entry_price  = na
var float target_price = na
var float current_stop = na

is_long_entry  = valid_long  and strategy.position_size <= 0
is_short_entry = valid_short and strategy.position_size >= 0

// Entries — strategy.entry handles reversal automatically when going opposite direction
if is_long_entry
    strategy.entry("Long", strategy.long)
    entry_price  := close
    current_stop := close - stop_dist
    target_price := use_tp ? close + stop_dist * rr_ratio : na
    alert("LONG entry — cross+filters", alert.freq_once_per_bar)

if is_short_entry
    strategy.entry("Short", strategy.short)
    entry_price  := close
    current_stop := close + stop_dist
    target_price := use_tp ? close - stop_dist * rr_ratio : na
    alert("SHORT entry — cross+filters", alert.freq_once_per_bar)

// Maintain trailing stop + post exit while in a position
if strategy.position_size > 0
    if use_trail
        current_stop := math.max(current_stop, high - trail_dist)
    strategy.exit("L-Exit", from_entry="Long", stop=current_stop, limit=target_price)

if strategy.position_size < 0
    if use_trail
        current_stop := math.min(current_stop, low + trail_dist)
    strategy.exit("S-Exit", from_entry="Short", stop=current_stop, limit=target_price)

// Opposite-cross optional exit
if exit_on_opp_cross
    if strategy.position_size > 0 and cross_down
        strategy.close("Long", comment="OppCross")
    if strategy.position_size < 0 and cross_up
        strategy.close("Short", comment="OppCross")

// Reset bookkeeping when flat
if strategy.position_size == 0
    entry_price  := na
    target_price := na
    current_stop := na

// ═════════════════════════════════════════════
//  PLOTS
// ═════════════════════════════════════════════
plot(fast_ma,  title="Fast MA",  color=color.new(color.aqua,   0), linewidth=2)
plot(slow_ma,  title="Slow MA",  color=color.new(color.orange, 0), linewidth=2)
plot(trend_ma, title="Trend MA", color=color.new(color.gray,  30), linewidth=1)

plot(strategy.position_size != 0 ? current_stop : na,
     title="Active Stop", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=1)
plot(strategy.position_size != 0 ? target_price : na,
     title="Take Profit", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=1)

plotshape(valid_long,  title="LONG",  style=shape.labelup,   location=location.belowbar,
     color=color.new(color.lime, 0), textcolor=color.black, text="LONG",  size=size.small)
plotshape(valid_short, title="SHORT", style=shape.labeldown, location=location.abovebar,
     color=color.new(color.red,  0), textcolor=color.white, text="SHORT", size=size.small)

plotshape(filtered_long,  title="Filtered Long",  style=shape.xcross, location=location.belowbar,
     color=color.new(color.gray, 0), size=size.tiny)
plotshape(filtered_short, title="Filtered Short", style=shape.xcross, location=location.abovebar,
     color=color.new(color.gray, 0), size=size.tiny)

in_long  = strategy.position_size > 0
in_short = strategy.position_size < 0
bgcolor(in_long  ? color.new(color.lime, 92) : in_short ? color.new(color.red, 92) : na, title="Position Background")
