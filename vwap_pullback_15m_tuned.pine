//@version=6
// ═════════════════════════════════════════════════════════════════
//  VWAP Pullback — ML-Tuned for 15m intraday
//
//  Parameters found via 500-iter guided random search across 3 seeds
//  on the same 8 stocks (TSLA NVDA AAPL NFLX AMZN PLTR SOFI HOOD)
//  using 60 days of 15m bars (commission 0.2% round-trip).
//
//  Aggregate result across 8 tickers (60 days):
//     PnL avg:  +5.30%    (target ≥5%   ✓)
//     Win avg:   54.8%    (target ≥55%  — short by 0.2pp, noise-level)
//     PF avg:    2.50     (target ≥2.0  ✓)
//     Trades:    84 across 8 tickers
//
//  Per-stock (60-day window):
//     TSLA  +8.4% / 40% win / PF 3.05  (10 trades)
//     NVDA  +2.7% / 54% win / PF 1.50  (13 trades)
//     AAPL  +1.0% / 56% win / PF 1.18  (16 trades)
//     NFLX  +6.6% / 71% win / PF 4.66  ( 7 trades)
//     AMZN  +4.7% / 58% win / PF 1.83  (12 trades)
//     PLTR  +3.7% / 80% win / PF 3.23  ( 5 trades)
//     SOFI  -3.7% / 25% win / PF 0.56  ( 8 trades)  ← only losing stock
//     HOOD +19.0% / 54% win / PF 4.00  (13 trades)  ← biggest contributor
//
//  ⚠ 60 days is a short backtest window. Numbers will vary materially
//     across different 60-day windows. Treat the result as directionally
//     positive, not as a guaranteed expectation.
// ═════════════════════════════════════════════════════════════════
strategy("VWAP Pullback 15m Tuned", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     pyramiding=0,
     process_orders_on_close=true,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=2)

// ─────────────────────────────────────────────
//  INPUTS — defaults are the ML-found 15m optimum
// ─────────────────────────────────────────────

// Regime
vwap_rising_lookback   = input.int(5,    "VWAP rising lookback (bars)", minval=2, group="Regime")
ema_len                = input.int(100,  "EMA length",                  minval=2, group="Regime")
require_ema_above_vwap = input.bool(false, "Require EMA > VWAP",                    group="Regime")

// Pullback
pullback_lookback    = input.int(3,    "Pullback lookback (bars)",          minval=2, maxval=30, group="Pullback")
vwap_touch_tolerance = input.float(0.5, "VWAP touch tolerance %", step=0.05, minval=0.0, group="Pullback")

// Volume
use_vol_filter = input.bool(true, "Require volume above MA × mult",     group="Volume")
vol_ma_len     = input.int(20,    "Volume MA length",       minval=1,   group="Volume")
vol_mult       = input.float(2.0, "Volume multiplier",      step=0.1,
                                  minval=0.1,                            group="Volume")

// Session
use_session_filter = input.bool(true,          "Session window filter",      group="Session")
session_window     = input.session("0930-1545", "Trade session (NY time)",   group="Session")
skip_first_bars    = input.int(0,    "Skip first N bars of each day",        group="Session")
force_close_eod    = input.bool(true, "Force-close at session end",          group="Session")

// Exits
atr_len           = input.int(7,    "ATR length",                  minval=1,  group="Exits")
init_stop_atr     = input.float(2.0, "Initial stop = ATR ×",        step=0.1, minval=0.5, group="Exits")
take_profit_r     = input.float(4.0, "Take profit = R ×",           step=0.1, minval=0.5, group="Exits")
exit_on_vwap_loss = input.bool(false, "Exit if close < VWAP",                 group="Exits")

// ─────────────────────────────────────────────
//  CALCULATIONS
// ─────────────────────────────────────────────
vwap_val = ta.vwap
ema_val  = ta.ema(close, ema_len)
atr_val  = ta.atr(atr_len)
vol_ma   = ta.sma(volume, vol_ma_len)
vol_ok   = not use_vol_filter or volume > vol_ma * vol_mult

// Bars since session start
var int bars_since_session_start = 0
new_day = not na(time(timeframe.period, "0930-0945"))
if new_day or (use_session_filter and na(time(timeframe.period, session_window)) and not na(time(timeframe.period, session_window)[1]))
    bars_since_session_start := 0
else
    bars_since_session_start += 1

// Regime
vwap_rising  = vwap_val > vwap_val[vwap_rising_lookback]
ema_above    = not require_ema_above_vwap or ema_val > vwap_val
in_session   = not use_session_filter or not na(time(timeframe.period, session_window))
past_warmup  = bars_since_session_start >= skip_first_bars
regime_long  = vwap_rising and ema_above and in_session and past_warmup

// Pullback detection
vwap_upper_tol = vwap_val * (1 + vwap_touch_tolerance / 100)
recent_touch   = false
for i = 1 to pullback_lookback
    if low[i] <= vwap_upper_tol[i]
        recent_touch := true

// Bounce confirmation
bounce_now = close > vwap_val and close > open and close > close[1]
buy_signal = regime_long and recent_touch and bounce_now and vol_ok

// ─────────────────────────────────────────────
//  STRATEGY
// ─────────────────────────────────────────────
var float entry_price = na
var float stop_price  = na
var float tp_price    = na

session_ending = use_session_filter and na(time(timeframe.period, session_window)) and not na(time(timeframe.period, session_window)[1])

if buy_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    entry_price := close
    stop_price  := close - atr_val * init_stop_atr
    tp_price    := close + atr_val * init_stop_atr * take_profit_r
    alert("BUY — VWAP pullback bounce (15m)", alert.freq_once_per_bar)

if strategy.position_size > 0
    strategy.exit("OCO", from_entry="Long", stop=stop_price, limit=tp_price)

    if exit_on_vwap_loss and ta.crossunder(close, vwap_val)
        strategy.close("Long", comment="VWAPlost")
        alert("SELL — close below VWAP", alert.freq_once_per_bar)

    if force_close_eod and session_ending
        strategy.close("Long", comment="EOD")
        alert("SELL — EOD close", alert.freq_once_per_bar)

if strategy.position_size == 0
    entry_price := na
    stop_price  := na
    tp_price    := na

// ─────────────────────────────────────────────
//  PLOTS
// ─────────────────────────────────────────────
plot(vwap_val, "VWAP",     color=color.new(color.purple, 0), linewidth=2)
plot(ema_val,  "EMA(100)", color=color.new(color.orange, 0), linewidth=2)

plot(strategy.position_size > 0 ? stop_price : na, "Stop",
     color=color.new(color.red, 0), style=plot.style_linebr, linewidth=1)
plot(strategy.position_size > 0 ? tp_price : na, "TP",
     color=color.new(color.green, 0), style=plot.style_linebr, linewidth=1)

in_trade = strategy.position_size > 0
bgcolor(in_trade ? color.new(color.lime, 92)
                 : (regime_long ? color.new(color.green, 96) : na),
       title="Regime/In-Trade")
bgcolor(use_session_filter and not in_session ? color.new(color.gray, 92) : na, title="Out-of-Session")

plotshape(buy_signal and strategy.position_size == 0,
     title="BUY", style=shape.labelup, location=location.belowbar,
     color=color.new(color.lime, 0), text="BUY", textcolor=color.black, size=size.tiny)
